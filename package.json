    "@wdio/appium-service": "^9.20.1",
    "@wdio/local-runner": "^9.20.1",
    "@wdio/mocha-framework": "^9.20.1",
    "@wdio/spec-reporter": "^9.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
